# Backend Environment Variables Template
# Copy this file to .env and fill in the values

# Server port
PORT=1337

# CORS origin (use * for development, specific domain for production)
CORS_ORIGIN=*

# Environment mode
NODE_ENV=development

# MongoDB connection string
# Format: mongodb://username:password@host:port/database
# Example: mongodb://wsadmin:password@localhost:27017
MONGO_CONNECT=mongodb://wsadmin:password@localhost:27017

# Email configuration for password reset
SUPPORT_EMAIL_PASSWORD=your_email_password_here

# Custom hash for password reset security
PASSWORD_RESET_HASH=your_custom_secure_hash_here
