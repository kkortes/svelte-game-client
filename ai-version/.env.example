# Frontend Environment Variables Template
# Copy this file to .env.local and fill in the values

# WebSocket connection URL for the game server
# Development: ws://localhost:1337
# Production: wss://your-game-server.com
VITE_WEBSOCKET_CONNECT=ws://localhost:1337

# Environment name
# Values: development | production | preview
VITE_VERCEL_ENV=development

# Auto-login credentials (development only, optional)
# Leave empty to require manual login
VITE_AUTO_EMAIL=
VITE_AUTO_PASSWORD=
